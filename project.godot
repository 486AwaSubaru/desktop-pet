; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="desktop_pet"
run/main_scene="uid://d0a15yoh758ju"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

GlobalInit="*uid://cdq71askd82w3"
MessageManage="*uid://tokfgcxy84jl"
LlmRequest="*uid://d201ds0a7qlkt"
EventBus="*uid://bl7xoovyhv3no"

[display]

window/size/viewport_width=300
window/size/viewport_height=550
window/size/borderless=true
window/size/always_on_top=true
window/size/transparent=true
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"
